# Copy to .env and fill in secrets:
#   cp .env.example .env

DATABASE_URL=postgres://mctracker:mctracker@localhost:5432/mctracker

# VictoriaMetrics / Prometheus `environment` label (metrics push + queries)
# Use `production` to match Grafana dashboard.yml; `development` enables local Vite CORS.
ENVIRONMENT=development

# Required — free GeoLite2 key from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
MAXMIND_LICENSE_KEY=

# Directory for GeoLite2-ASN MMDB files (default: databases)
MAXMIND_DATABASE_DIR=databases

# Bootstrap admin (only used when the users table is empty)
MC_TRACKER_ADMIN_USERNAME=admin
MC_TRACKER_ADMIN_PASSWORD=changeme

# Session secret (required) - openssl rand -base64 32
SESSION_SECRET=change-me

# Optional VictoriaMetrics auth (leave empty for local docker-compose VM)
VICTORIAMETRICS_AUTH_TOKEN=

# Logging
RUST_LOG=info,mc_tracker=debug,mc_geo=info,mc_chat=info

# Optional — used by scripts/dev.sh for www/.env when missing
# VITE_MC_TRACKER_API_URL=http://localhost:3000

# LLM chat agent (optional — POST /chat returns 503 when unset)
# OpenRouter example:
# LLM_BASE_URL=https://openrouter.ai/api
# LLM_MODEL=anthropic/claude-sonnet-4
# LLM_API_KEY=sk-or-...
# LLM_CTX_SIZE=200000
# Local llama.cpp example:
# LLM_BASE_URL=http://localhost:8080
# LLM_MODEL=default
# LLM_PARALLEL_SLOTS=2
# LLM_CTX_SIZE=16384
# LLM_TIMEOUT_SECS=60
